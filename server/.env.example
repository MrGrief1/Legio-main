# Server Environment Variables
# Copy this to .env and fill in the values

# Server Configuration
PORT=3001
HOST=0.0.0.0
# Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET_KEY=replace-with-a-random-secret-at-least-32-characters-long

# Bootstrap admin creation is disabled in production by default.
# Set to true only for the very first trusted registration.
ALLOW_BOOTSTRAP_ADMIN=false

# Optional comma-separated list of logins that must be admins.
# Leave empty unless you explicitly need this override.
FORCED_ADMIN_LOGINS=

# Optional salt for visit deduplication. Defaults to SECRET_KEY when empty.
VISITOR_ID_HASH_SALT=

# CORS Configuration (optional)
# Leave empty to allow all origins (development mode)
# Set in production: ALLOWED_ORIGINS=https://your-frontend.railway.app,https://your-domain.com
ALLOWED_ORIGINS=

# CSP Connect Origins (optional)  
# Leave empty for default localhost
# Set in production: CSP_CONNECT_ORIGINS='self' https://your-frontend.railway.app
CSP_CONNECT_ORIGINS=

# Frontend URL (for reference)
FRONTEND_URL=http://localhost:3000

# Legacy WordPress / MySQL sync (optional)
# Set these when migrating old legio.news data into this project.
WP_DB_HOST=
WP_DB_PORT=3306
WP_DB_USER=
WP_DB_PASSWORD=
WP_DB_NAME=
WP_DB_PREFIX=wp_

# Run sync automatically when backend starts
WP_SYNC_ON_STARTUP=false

# true: fully replace local SQLite content with legacy WordPress data
# false: keep existing data and upsert where possible
WP_SYNC_FULL_REPLACE=true
